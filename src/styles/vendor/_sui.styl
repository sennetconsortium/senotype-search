.sui-facet
  border 0
  margin 0
  padding 0
  font-family -apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica,Arial,sans-serif
  font-weight 400
  line-height 1.5

  &__title
    text-transform uppercase
    color $col-bali-hai
    letter-spacing 1px
    padding 0
    font-size 12px
    outline none !important

  &__list
    margin 8px 0
    padding 0
    font-size 13px
    line-height 1.5

  &__count
    color $col-grey
    margin-left 20px
    padding-top 2px
    font-size .85em
    display inline-block

  &-view-more
    cursor pointer
    color $col-primary-blue
    font-family inherit
    font-size 13px
    line-height inherit
    text-align left
    border unset
    padding unset
    background unset
    display block

    &:hover,&:focus
      background-color $col-alabaster-grey
      outline 4px solid $col-alabaster-grey

  &-search
    margin 6px 0 0

    &__text-input
      border 1px solid $col-chalice
      border-radius 4px
      outline none
      width 100%
      height 100%
      margin 0
      padding 6px
      font-family inherit
      &:focus
        border 1px solid  $col-primary-blue

.sui-facet+.sui-facet,.sui-sorting+.sui-facet
  margin-top 32px


.sui-multi-checkbox-facet
  color $col-emp-grey
  margin 8px 0
  font-size 13px
  &__option-input-wrapper
    display flex
    flex-direction row
    align-items center
    flex inherit

  &__option-label
    cursor pointer
    justify-content space-between
    align-items center
    display flex

  &__option-input-wrapper
    flex 1

  &__checkbox
    cursor pointer
    margin-right 8px

  &__option-count
    color $col-grey
    margin-left 24px
    font-size .85em

.sui-boolean-facet
  color $col-emp-grey
  margin 8px 0
  font-size 13px

  &__option-label
    cursor pointer
    justify-content space-between
    align-items center
    display flex

  &__option-input-wrapper
    flex 1

  &__checkbox
    cursor pointer
    margin-right 8px

  &__option-count
    color $col-grey
    margin-left 24px
    font-size .85em

.sui-single-option-facet
  margin 8px 0
  padding 0
  font-size 13px
  list-style none

  &__item
    justify-content space-between
    display flex

  &__link
    color $col-emp-grey
    padding 0
    font-weight 700
    text-decoration none
    list-style none
    position relative
    &:after
      content ""
      opacity 0
      pointer-events none
      background  $col-primary-blue
      width calc(100% + 10px)
      height calc(100% + 2px)
      position absolute
      top -1px
      left -5px
    &:focus
      color  $col-primary-blue
      outline none
      font-weight 700
    &:hover
      color  $col-primary-blue
      font-weight 700
      &:after
        opacity 1

  &__selected
    font-weight 900
    list-style none
    a
      padding 0 2px
      font-weight 100

  &__remove
    color #666
    margin-left 10px


/*Custom*/
.sui-facet 
  max-height 500px
  overflow-y auto

  &__title 
    outline none !important

    &--FileType + .sui-facet 
      text-transform uppercase

.sui-multi-checkbox-facet 
  &__option-input-wrapper
    display flex
    flex-direction row
    align-items center
    flex inherit

  &__option-count
    color grey

  &__checkbox,
  &__input-text
    display table-cell
  

.sui-facet__RegisteredBy 
  .sui-multi-checkbox-facet 
    &__input-text 
      max-width 140px
      text-overflow ellipsis
      white-space nowrap
      overflow hidden