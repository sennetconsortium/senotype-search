{
  "name": "senotype-library",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "all": "npm-run-all --parallel dev css",
    "dev": "next dev --port 3002",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pretty-check": "pnpm exec prettier --check .",
    "pretty-fix": "pnpm exec prettier --write .",
    "css": "stylus --include-css --compress -w src/styles/main.styl -o src/app/main.css"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@emotion/styled": "^11.14.1",
    "antd": "^6.3.5",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "cookies-next": "^6.1.1",
    "next": "16.2.1",
    "npm-run-all": "^4.1.5",
    "react": "19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-dom": "19.2.4",
    "search-ui": "workspace:*",
    "stylus": "^0.64.0",
    "xac-loglevel": "github:x-atlas-consortia/xac-loglevel#1.0.2"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prettier": "^3.8.1"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": true
  }
}
